.vscode/
.idea/
*.code-workspace
.history/

# Local CommandCode data
.commandcode/

# Coverage reports
*.lcov
coverage/
.nyc_output/

# Build / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.dist-info/

# Profiling
*.prof
*.lprof
.pytest_cache/
.tox/
.coverage
coverage.xml
*.cover

