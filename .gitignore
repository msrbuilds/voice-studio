# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
.installed.cfg
*.egg

# Virtual environments
venv/
# Isolated per-engine venvs (Chatterbox, OmniVoice, …). The glob covers any
# future `venv-<engine>/`; these hold bundled deps (e.g. Gradio's frontend =
# thousands of JS chunks) and must never be tracked.
venv-*/
venv-chatterbox/
venv-omnivoice/
.venv/
# uv's shared package cache (repo-local, on the venvs' volume so uv hardlinks
# into each venv). Large runtime store — never tracked.
.uv-cache/
# Vendored engine source clones (ACE-Step) + their uv-sync'd .venv. Build
# artifacts fetched by `studio.py install-acestep`, never tracked.
backend/vendor/
env/
.env
ENV/
.nox/
.pyenv/
.python-version

# Test / lint / type artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.cache/
.pyright/

# Jupyter
.ipynb_checkpoints/

# --- Node / frontend ---
node_modules/
dist/
.vite/
*.tsbuildinfo
.npm/
.yarn/
.pnp.*

# --- Backend runtime data ---
# Per-segment synthesis cache (regenerated on first run)
backend/cache/
backend/cache/*
!backend/cache/.gitkeep

# User-uploaded voices (PII / copyrighted material)
backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/voices.json

# Built-in voice reference clips are private recordings; only
# the metadata manifest is tracked. If you want to commit
# actual built-in WAVs, drop `!backend/voices/*.wav` etc. below.
backend/voices/*.wav
backend/voices/*.mp3
backend/voices/*.flac
backend/voices/*.ogg
!backend/voices/README.md
!backend/voices/voices.json
!backend/voices/.gitkeep

# VibeVoice reference audio (1.5B model lives under HF cache)
# Project-local HuggingFace model cache (VibeVoice 1.5B, Kokoro-82M, etc.)
backend/models/
checkpoints/
models/
*.safetensors
*.bin
*.pt
*.pth

# --- Environment / secrets ---
.env
.env.local
.env.*.local
*.pem
secrets/

# --- Logs / temp / scratch ---
*.log
*.tmp
*.temp
*.swp
*.swo
debug.log
smoke*.log
*.bak

# Captured process stdout/stderr from manual runs (backend.err/out, vite.err/out)
*.err
*.out

# Ad-hoc /api/config dumps saved during manual testing
/cfg*.json

# Runtime state: last-selected engine (written by EngineManager at runtime)
backend/.last_engine

# Test artifacts
test_join.wav
test_*.wav
seg*.wav
app.tmp

